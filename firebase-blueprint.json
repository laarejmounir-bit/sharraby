{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user in the system (could be admin or staff)",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["super_admin", "admin", "support", "warehouse"] },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "name", "role", "createdAt"]
    },
    "Customer": {
      "title": "Customer",
      "description": "Customer Profile",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "phone": { "type": "string" },
        "city": { "type": "string" },
        "totalOrders": { "type": "number" },
        "totalSpend": { "type": "number" },
        "lastOrderDate": { "type": "string" },
        "createdAt": { "type": "string", "description": "Timestamp ISO" }
      },
      "required": ["name", "phone", "totalOrders", "totalSpend", "createdAt"]
    },
    "Product": {
      "title": "Product",
      "description": "Product Catalog entry",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" },
        "stock": { "type": "number" },
        "active": { "type": "boolean" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["name", "price", "stock", "active", "createdAt", "updatedAt"]
    },
    "Order": {
      "title": "Order",
      "description": "Order Information",
      "type": "object",
      "properties": {
        "orderNumber": { "type": "string" },
        "customerId": { "type": "string" },
        "customerName": { "type": "string" },
        "customerPhone": { "type": "string" },
        "city": { "type": "string" },
        "district": { "type": "string" },
        "address": { "type": "string" },
        "items": {
          "type": "array",
          "items": { "type": "object" }
        },
        "totalAmount": { "type": "number" },
        "shippingCost": { "type": "number" },
        "paymentMethod": { "type": "string" },
        "status": { "type": "string" },
        "orderDate": { "type": "string" },
        "notes": { "type": "string" },
        "history": { "type": "array" }
      },
      "required": ["orderNumber", "customerName", "customerPhone", "city", "address", "items", "totalAmount", "shippingCost", "paymentMethod", "status", "orderDate"]
    },
    "InventoryLog": {
      "title": "InventoryLog",
      "description": "Logs when inventory changes",
      "type": "object",
      "properties": {
        "productId": { "type": "string" },
        "change": { "type": "number" },
        "newStock": { "type": "number" },
        "reason": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["productId", "change", "newStock", "reason", "createdAt"]
    },
    "Notification": {
      "title": "Notification",
      "description": "System Notifications",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string" },
        "read": { "type": "boolean" },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "message", "type", "read", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "System users and their roles"
    },
    "customers/{customerId}": {
      "schema": "Customer",
      "description": "Customer database"
    },
    "products/{productId}": {
      "schema": "Product",
      "description": "Product catalog"
    },
    "orders/{orderId}": {
      "schema": "Order",
      "description": "Order records"
    },
    "inventoryLogs/{logId}": {
      "schema": "InventoryLog",
      "description": "Inventory movement history"
    },
    "notifications/{notificationId}": {
      "schema": "Notification",
      "description": "System alerts"
    }
  }
}
